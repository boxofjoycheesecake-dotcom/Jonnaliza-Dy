rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Site Config
    match /siteConfigs/{configId} {
      allow read: if true;
      // Allow write during setup - in a real app, this would be restricted to admin
      allow write: if true; 
    }
  }
}
